{
  "name": "electron-trading-terminal",
  "version": "1.0.0",
  "description": "Production-like Electron trading terminal demo",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:main": "tsup src/main/index.ts src/main/preload.ts --format cjs --out-dir dist/main --sourcemap --external electron --watch",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js && nodemon --watch dist/main --ext js --exec \"env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup src/main/index.ts src/main/preload.ts --format cjs --out-dir dist/main --sourcemap --external electron",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "start": "env -u ELECTRON_RUN_AS_NODE electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "reselect": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  }
}
